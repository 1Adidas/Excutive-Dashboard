# ============================================================
# Cấu hình kết nối Database
# Sao chép file này thành .env và điều chỉnh giá trị phù hợp
# ============================================================

# SQL Server Configuration
DB_SERVER=localhost
DB_PORT=1433

# HR Legacy Database (Read-Only)
HR_DB_NAME=HR_Legacy_DB

# Payroll Legacy Database (Read-Only)
PAYROLL_DB_NAME=Payroll_Legacy_DB

# Authentication: Sử dụng Windows Authentication (Trusted Connection)
# Nếu dùng SQL Server Authentication, bỏ comment 2 dòng dưới:
# DB_USER=your_username
# DB_PASSWORD=your_password

# Server Configuration
PORT=3000

# Alert Thresholds
MAX_VACATION_DAYS=15
ANNIVERSARY_ALERT_DAYS=30
